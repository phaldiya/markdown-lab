{
  "name": "markdown-lab",
  "private": true,
  "version": "1.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "format": "biome format --write .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "vitest run tests/smoke/",
    "test:deep": "vitest run tests/deep/",
    "test:coverage": "vitest run --coverage",
    "build:extension": "vite build --config vite.config.extension.ts",
    "verify": "vitest run && playwright test",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:functional": "playwright test --project=functional",
    "e2e:visual": "playwright test --project=visual-desktop --project=visual-tablet --project=visual-mobile",
    "e2e:update-snapshots": "playwright test --project=visual-desktop --project=visual-tablet --project=visual-mobile --update-snapshots",
    "install-browse": "bunx playwright install chromium --with-deps",
    "extension:icons": "bun run scripts/generate-icons.ts",
    "extension:zip": "bun run scripts/package-extension.ts",
    "setup-hooks": "sh ./scripts/setup-hooks.sh all"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@uiw/react-codemirror": "^4.25.9",
    "dompurify": "^3.4.1",
    "hast-util-to-html": "^9.0.5",
    "katex": "^0.16.45",
    "mermaid": "^11.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-emoji": "^5.0.2",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "yaml": "^2.8.3"
  },
  "overrides": {
    "picomatch": ">=4.0.4",
    "handlebars": ">=4.7.9",
    "lodash": ">=4.18.0",
    "lodash-es": ">=4.18.0",
    "dompurify": ">=3.4.1",
    "undici": ">=7.24.0",
    "minimatch": ">=10.2.3",
    "tar": ">=7.5.11",
    "yaml": ">=2.8.3",
    "rollup": ">=4.59.0",
    "brace-expansion": ">=5.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@playwright/test": "1.59.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/dompurify": "^3.2.0",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@types/sharp": "^0.32.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.0.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
